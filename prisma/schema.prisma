generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  BUSINESS
  ADMIN
}

enum SupplierSource {
  MANUAL
  SCRAPED
  AI_DISCOVERED
}

enum MatchStatus {
  RECOMMENDED
  BOOKED
  DISMISSED
}

enum BookingStatus {
  PENDING_REVIEW
  APPROVED
  CONNECTED
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  REQUESTED
  PRICED
  ACCEPTED
  EXPIRED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
}

enum LeadStatus {
  PROSPECT
  CONTACTED
  NEGOTIATING
  CONVERTED
  LOST
}

enum LeadPriority {
  HIGH
  MEDIUM
  LOW
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String?
  role          UserRole       @default(BUSINESS)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  business      Business?
  notifications Notification[]
  sentMessages  Message[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String   @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model Business {
  id               String           @id @default(cuid())
  userId           String           @unique
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  industry         String
  location         String
  description      String           @db.Text
  operatingDetails Json?
  profileComplete  Boolean          @default(false)
  stripeCustomerId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  items            BusinessItem[]
  matches          SupplierMatch[]
  bookings         BookingRequest[]
  quotes           Quote[]
  orders           Order[]
  recurringOrders  RecurringOrder[]
}

model BusinessItem {
  id                String   @id @default(cuid())
  businessId        String
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name              String
  category          String
  description       String?  @db.Text
  estimatedQuantity String?
  purchaseFrequency String?
  specifications    String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Supplier {
  id              String           @id @default(cuid())
  name            String
  industry        String?
  location        String?
  website         String?
  contactInfo     String?          @db.Text
  description     String?          @db.Text
  categories      Json?
  source          SupplierSource   @default(MANUAL)
  verified        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  matches         SupplierMatch[]
  bookings        BookingRequest[]
  quotes          Quote[]
  orders          Order[]
  recurringOrders RecurringOrder[]
}

model SupplierMatch {
  id          String        @id @default(cuid())
  businessId  String
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  matchScore  Float
  aiReasoning String?       @db.Text
  aiSummary   String?       @db.Text
  status      MatchStatus   @default(RECOMMENDED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  booking     BookingRequest?
}

model BookingRequest {
  id              String        @id @default(cuid())
  businessId      String
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  matchId         String        @unique
  match           SupplierMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  status          BookingStatus @default(PENDING_REVIEW)
  adminNotes      String?       @db.Text
  businessMessage String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  quotes          Quote[]
}

model Quote {
  id            String          @id @default(cuid())
  businessId    String
  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId    String
  supplier      Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  bookingId     String
  booking       BookingRequest  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status        QuoteStatus     @default(REQUESTED)
  subtotal      Float?
  platformFee   Float?
  total         Float?
  businessNotes String?         @db.Text
  adminNotes    String?         @db.Text
  expiresAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  lineItems      QuoteLineItem[]
  orders         Order[]
  recurringOrder RecurringOrder?
  messages       Message[]
}

model QuoteLineItem {
  id          String @id @default(cuid())
  quoteId     String
  quote       Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name        String
  description String? @db.Text
  quantity    Float
  unit        String?
  unitPrice   Float?
  lineTotal   Float?
}

model Order {
  id                      String      @id @default(cuid())
  businessId              String
  business                Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId              String
  supplier                Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  quoteId                 String
  quote                   Quote       @relation(fields: [quoteId], references: [id])
  status                  OrderStatus @default(PENDING_PAYMENT)
  subtotal                Float
  platformFee             Float
  total                   Float
  stripePaymentIntentId   String?
  stripeCheckoutSessionId String?
  recurringOrderId        String?
  recurringOrder          RecurringOrder? @relation(fields: [recurringOrderId], references: [id])
  cycleNumber             Int?
  adminNotes              String?     @db.Text
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  lineItems               OrderLineItem[]
  messages                Message[]
}

model OrderLineItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name        String
  description String? @db.Text
  quantity    Float
  unit        String?
  unitPrice   Float
  lineTotal   Float
}

model Lead {
  id              String         @id @default(cuid())
  businessName    String
  website         String?
  industry        String
  isFranchise     Boolean        @default(false)
  locationCount   Int            @default(1)
  address         String?
  city            String         @default("Austin")
  state           String         @default("TX")
  zip             String?
  generalPhone    String?
  generalEmail    String?
  managerName     String?
  managerEmail    String?
  managerPhone    String?
  ceoName         String?
  ceoEmail        String?
  ceoPhone        String?
  additionalContacts String?     @db.Text
  notes           String?        @db.Text
  status          LeadStatus     @default(PROSPECT)
  priority        LeadPriority   @default(MEDIUM)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  locations       LeadLocation[]
}

model LeadLocation {
  id           String  @id @default(cuid())
  leadId       String
  lead         Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name         String
  address      String?
  city         String  @default("Austin")
  state        String  @default("TX")
  zip          String?
  phone        String?
  managerName  String?
  managerEmail String?
  managerPhone String?
  notes        String? @db.Text

  @@index([leadId])
}

model RecurringOrder {
  id                   String              @id @default(cuid())
  businessId           String
  business             Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId           String
  supplier             Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  quoteId              String              @unique
  quote                Quote               @relation(fields: [quoteId], references: [id])
  status               SubscriptionStatus  @default(ACTIVE)
  frequency            RecurringFrequency
  nextOrderDate        DateTime
  stripeCustomerId     String?
  stripePaymentMethodId String?
  itemsSnapshot        Json
  subtotal             Float
  platformFee          Float
  total                Float
  skipNext             Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  orders               Order[]
}

model Message {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  quoteId   String?
  quote     Quote?   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([quoteId])
  @@index([orderId])
}
